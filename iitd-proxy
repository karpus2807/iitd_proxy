#!/usr/bin/env python3
"""
IIT Delhi proxy setup helper for Ubuntu 16.04 through 26.04.

This script intentionally keeps dependencies minimal. It configures the proxy
for Ubuntu's system tools, installs only mandatory missing packages, and skips
optional software such as git, curl, wget, snapd, tmux, npm, pip, and flatpak.
"""

import argparse
import getpass
import json
import os
import platform
import pwd
import shutil
import socket
import ssl
import subprocess
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from html.parser import HTMLParser
from pathlib import Path


PREFIX_MAP = {
    "phd": 61,
    "mtech": 62,
    "btech": 22,
    "staff": 78,
    "faculty": 82,
    "visitor": 21,
}

LOGIN_URL_MAP = {
    "staff": "https://proxy21.iitd.ac.in/cgi-bin/proxy.cgi",
    "faculty": "https://proxy82.iitd.ac.in/cgi-bin/proxy.cgi",
    "visitor": "https://proxy21.iitd.ac.in/cgi-bin/proxy.cgi",
}

PROXY_PORT = 3128
NO_PROXY = "localhost,127.0.0.1,::1"
MANDATORY_PACKAGES = ("python3", "python3-requests", "ca-certificates")

APT_PROXY_FILE = Path("/etc/apt/apt.conf.d/95iitd-proxy")
ENV_FILE = Path("/etc/environment")
PROFILE_FILE = Path("/etc/profile.d/iitd-proxy.sh")
SYSTEMD_SYSTEM_DIR = Path("/etc/systemd/system.conf.d")
SYSTEMD_USER_DIR = Path("/etc/systemd/user.conf.d")
SYSTEMD_PROXY_FILE = SYSTEMD_SYSTEM_DIR / "95iitd-proxy.conf"
SYSTEMD_USER_PROXY_FILE = SYSTEMD_USER_DIR / "95iitd-proxy.conf"
STATE_DIR = Path("/var/lib/iitd-proxy")
STATE_FILE = STATE_DIR / "state.json"
LOG_FILE = Path("/var/log/iitd_proxy_setup.log")


class ProxyError(RuntimeError):
    """Raised when a proxy setup step fails."""


class SessionParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.sessionid = None

    def handle_starttag(self, tag, attrs):
        if tag != "input":
            return

        data = dict(attrs)
        if data.get("name") == "sessionid":
            self.sessionid = data.get("value")


def log(message):
    stamp = time.strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{stamp}] {message}"
    print(message)
    try:
        LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
        with LOG_FILE.open("a", encoding="utf-8") as handle:
            handle.write(line + "\n")
    except OSError:
        fallback = Path("/tmp/iitd_proxy_setup.log")
        with fallback.open("a", encoding="utf-8") as handle:
            handle.write(line + "\n")


def run(cmd, check=True, timeout=None, env=None):
    log("+ " + " ".join(cmd))
    try:
        completed = subprocess.run(
            cmd,
            check=False,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=timeout,
            env=env,
        )
    except subprocess.TimeoutExpired as exc:
        output = exc.stdout or ""
        if isinstance(output, bytes):
            output = output.decode("utf-8", errors="replace")
        log(f"  timed out after {timeout} seconds")
        if output.strip():
            for line in output.rstrip().splitlines():
                log("  " + line)
        if check:
            raise ProxyError(f"Command timed out after {timeout} seconds: {' '.join(cmd)}") from exc
        return subprocess.CompletedProcess(cmd, 124, stdout=output)

    if completed.stdout.strip():
        for line in completed.stdout.rstrip().splitlines():
            log("  " + line)
    if check and completed.returncode != 0:
        raise ProxyError(f"Command failed with exit code {completed.returncode}: {' '.join(cmd)}")
    return completed


def require_root():
    if os.geteuid() == 0:
        return
    raise ProxyError("System-wide setup needs root. Run: sudo ./iitd-proxy install <role> <userid>")


def detect_ubuntu():
    data = {}
    os_release = Path("/etc/os-release")
    if os_release.exists():
        for raw_line in os_release.read_text(encoding="utf-8", errors="ignore").splitlines():
            if "=" not in raw_line:
                continue
            key, value = raw_line.split("=", 1)
            data[key] = value.strip().strip('"')

    distro_id = data.get("ID", "").lower()
    version_id = data.get("VERSION_ID", "")
    codename = data.get("VERSION_CODENAME", data.get("UBUNTU_CODENAME", ""))

    if distro_id and distro_id != "ubuntu":
        log(f"Warning: detected {distro_id}, but this script is designed for Ubuntu.")

    supported = {"16.04", "18.04", "20.04", "22.04", "24.04", "26.04"}
    if version_id and version_id not in supported:
        log(f"Warning: Ubuntu {version_id} is not in the tested range 16.04-26.04.")

    return {
        "id": distro_id or platform.system(),
        "version": version_id or "unknown",
        "codename": codename or "unknown",
    }


def get_login_url(role, prefix):
    if role in LOGIN_URL_MAP:
        return LOGIN_URL_MAP[role]
    return f"https://proxy{prefix}.iitd.ac.in/cgi-bin/proxy.cgi"


def proxy_host(prefix):
    return f"10.10.{prefix}.21"


def proxy_url(prefix):
    return f"http://{proxy_host(prefix)}:{PROXY_PORT}/"


def proxy_env(prefix):
    url = proxy_url(prefix)
    env = os.environ.copy()
    env.update(
        {
            "http_proxy": url,
            "https_proxy": url,
            "ftp_proxy": url,
            "HTTP_PROXY": url,
            "HTTPS_PROXY": url,
            "FTP_PROXY": url,
            "no_proxy": NO_PROXY,
            "NO_PROXY": NO_PROXY,
        }
    )
    return env


def target_user_record():
    user = os.environ.get("SUDO_USER")
    if not user or user == "root":
        return None
    try:
        return pwd.getpwnam(user)
    except KeyError:
        return None


def managed_block(content):
    return (
        "# >>> iitd-proxy managed >>>\n"
        + content.rstrip()
        + "\n# <<< iitd-proxy managed <<<\n"
    )


def replace_managed_block(path, content):
    marker_start = "# >>> iitd-proxy managed >>>"
    marker_end = "# <<< iitd-proxy managed <<<"
    new_block = managed_block(content)

    if path.exists():
        existing = path.read_text(encoding="utf-8", errors="ignore")
        start = existing.find(marker_start)
        end = existing.find(marker_end)
        if start != -1 and end != -1:
            end += len(marker_end)
            existing = existing[:start].rstrip() + "\n\n" + existing[end:].lstrip()
        final = existing.rstrip() + "\n\n" + new_block
    else:
        final = new_block

    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(final, encoding="utf-8")


def remove_managed_block(path):
    marker_start = "# >>> iitd-proxy managed >>>"
    marker_end = "# <<< iitd-proxy managed <<<"
    if not path.exists():
        return

    existing = path.read_text(encoding="utf-8", errors="ignore")
    start = existing.find(marker_start)
    end = existing.find(marker_end)
    if start == -1 or end == -1:
        return

    end += len(marker_end)
    cleaned = (existing[:start].rstrip() + "\n" + existing[end:].lstrip()).strip()
    path.write_text((cleaned + "\n") if cleaned else "", encoding="utf-8")
    log(f"Removed managed proxy block from {path}")


def chown_to_user(path, user_info):
    try:
        os.chown(path, user_info.pw_uid, user_info.pw_gid)
    except OSError as exc:
        log(f"Could not change owner for {path}: {exc}")


def direct_https_opener(verify_tls=True):
    if verify_tls:
        sslctx = ssl.create_default_context()
    else:
        # IITD proxy login servers may present a chain missing from fresh Ubuntu
        # trust stores. This fallback is limited to the IITD login request only.
        sslctx = ssl._create_unverified_context()
    opener = urllib.request.build_opener(
        urllib.request.ProxyHandler({}),
        urllib.request.HTTPSHandler(context=sslctx),
    )
    return opener


def is_certificate_error(exc):
    text = str(exc).lower()
    return "certificate_verify_failed" in text or "certificate verify failed" in text


def login(role, prefix, user, password):
    base = get_login_url(role, prefix)
    opener = direct_https_opener()

    try:
        html = opener.open(base, timeout=20).read().decode("utf-8", errors="replace")
    except (ssl.SSLError, urllib.error.URLError) as exc:
        if not is_certificate_error(exc):
            raise ProxyError(f"Could not reach IITD proxy login page: {exc}") from exc
        log("IITD proxy login TLS verification failed; retrying login with IITD-only TLS fallback.")
        opener = direct_https_opener(verify_tls=False)
        try:
            html = opener.open(base, timeout=20).read().decode("utf-8", errors="replace")
        except (urllib.error.URLError, socket.timeout) as retry_exc:
            raise ProxyError(f"Could not reach IITD proxy login page: {retry_exc}") from retry_exc
    except (urllib.error.URLError, socket.timeout) as exc:
        raise ProxyError(f"Could not reach IITD proxy login page: {exc}") from exc

    parser = SessionParser()
    parser.feed(html)

    if not parser.sessionid:
        raise ProxyError("Session ID not found on IITD proxy login page.")

    form = {
        "sessionid": parser.sessionid,
        "action": "Validate",
        "userid": user,
        "pass": password,
    }
    data = urllib.parse.urlencode(form).encode()
    req = urllib.request.Request(base, data=data)

    try:
        response = opener.open(req, timeout=20).read().decode("utf-8", errors="replace")
    except (urllib.error.URLError, socket.timeout) as exc:
        raise ProxyError(f"IITD proxy login request failed: {exc}") from exc

    lowered = response.lower()
    if "successfully" in lowered or "already logged in" in lowered:
        log("IITD proxy login: OK")
        return

    raise ProxyError("IITD proxy login failed. Check role, userid, and password.")


def write_file(path, content, mode=0o644):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    path.chmod(mode)
    log(f"Updated {path}")


def configure_apt(prefix):
    url = proxy_url(prefix)
    content = f"""// Managed by iitd-proxy. Remove with: iitd-proxy remove
Acquire::http::Proxy "{url}";
Acquire::https::Proxy "{url}";
Acquire::ftp::Proxy "{url}";
Acquire::Retries "3";
"""
    write_file(APT_PROXY_FILE, content)


def parse_environment_file():
    if not ENV_FILE.exists():
        return []
    return ENV_FILE.read_text(encoding="utf-8", errors="ignore").splitlines()


def quote_env_value(value):
    return '"' + value.replace("\\", "\\\\").replace('"', '\\"') + '"'


def configure_environment(prefix):
    url = proxy_url(prefix)
    managed = {
        "http_proxy": url,
        "https_proxy": url,
        "ftp_proxy": url,
        "HTTP_PROXY": url,
        "HTTPS_PROXY": url,
        "FTP_PROXY": url,
        "no_proxy": NO_PROXY,
        "NO_PROXY": NO_PROXY,
    }

    existing = []
    managed_keys = set(managed)
    for line in parse_environment_file():
        key = line.split("=", 1)[0].strip() if "=" in line else ""
        if key not in managed_keys:
            existing.append(line)

    existing.extend(f"{key}={quote_env_value(value)}" for key, value in managed.items())
    ENV_FILE.write_text("\n".join(existing).rstrip() + "\n", encoding="utf-8")
    log(f"Updated {ENV_FILE}")

    profile_lines = [
        "# Managed by iitd-proxy. Remove with: iitd-proxy remove",
        f"export http_proxy={quote_env_value(url)}",
        f"export https_proxy={quote_env_value(url)}",
        f"export ftp_proxy={quote_env_value(url)}",
        f"export HTTP_PROXY={quote_env_value(url)}",
        f"export HTTPS_PROXY={quote_env_value(url)}",
        f"export FTP_PROXY={quote_env_value(url)}",
        f"export no_proxy={quote_env_value(NO_PROXY)}",
        f"export NO_PROXY={quote_env_value(NO_PROXY)}",
        "",
    ]
    write_file(PROFILE_FILE, "\n".join(profile_lines), 0o644)


def configure_systemd(prefix):
    url = proxy_url(prefix)
    content = f"""# Managed by iitd-proxy. Remove with: iitd-proxy remove
[Manager]
DefaultEnvironment="http_proxy={url}" "https_proxy={url}" "ftp_proxy={url}" "HTTP_PROXY={url}" "HTTPS_PROXY={url}" "FTP_PROXY={url}" "no_proxy={NO_PROXY}" "NO_PROXY={NO_PROXY}"
"""
    write_file(SYSTEMD_PROXY_FILE, content)
    write_file(SYSTEMD_USER_PROXY_FILE, content)

    if shutil.which("systemctl"):
        run(["systemctl", "daemon-reexec"], check=False, timeout=15)


def configure_snap(prefix):
    if not shutil.which("snap"):
        log("Snap: not installed, skipping without installing snapd.")
        return "SKIPPED"

    url = proxy_url(prefix).rstrip("/")
    result = run(["snap", "set", "system", f"proxy.http={url}", f"proxy.https={url}"], check=False, timeout=30)
    if result.returncode != 0:
        log("Snap proxy could not be configured.")
        return "CHECK"

    if shutil.which("systemctl"):
        # snapd is a daemon; restarting makes proxy changes take effect faster
        # after LAN/WLAN switches and avoids stale store connections.
        run(["systemctl", "restart", "snapd.service"], check=False, timeout=20)

    log("Snap proxy configured and snapd refreshed.")
    return "OK"


def configure_gsettings(prefix):
    if not shutil.which("gsettings"):
        log("GNOME gsettings: not installed, skipping.")
        return "SKIPPED"

    target_user = os.environ.get("SUDO_USER")
    display = os.environ.get("DISPLAY")
    if not target_user or not display:
        log("GNOME gsettings: no desktop user session detected, skipping.")
        return "SKIPPED"

    host = proxy_host(prefix)
    env = os.environ.copy()
    env["DISPLAY"] = display
    target_uid = None
    dbus = os.environ.get("DBUS_SESSION_BUS_ADDRESS")
    if not dbus:
        try:
            target_uid = pwd.getpwnam(target_user).pw_uid
            user_bus = Path(f"/run/user/{target_uid}/bus")
            if user_bus.exists():
                dbus = f"unix:path={user_bus}"
        except KeyError:
            dbus = None
    elif target_uid is None:
        try:
            target_uid = pwd.getpwnam(target_user).pw_uid
        except KeyError:
            target_uid = None

    if not dbus:
        log("GNOME gsettings: desktop DBus session not found, skipping.")
        return "SKIPPED"
    if target_uid is None:
        log("GNOME gsettings: desktop user not found, skipping.")
        return "SKIPPED"

    env["DBUS_SESSION_BUS_ADDRESS"] = dbus

    base = [
        "sudo",
        "-u",
        target_user,
        "env",
        f"DISPLAY={display}",
        f"DBUS_SESSION_BUS_ADDRESS={dbus}",
        f"XDG_RUNTIME_DIR=/run/user/{target_uid}",
    ]
    current_mode = run(base + ["gsettings", "get", "org.gnome.system.proxy", "mode"], check=False, timeout=10, env=env)
    if current_mode.returncode == 0:
        log(f"Current Ubuntu desktop proxy mode: {current_mode.stdout.strip() or 'unknown'}")
    commands = [
        base + ["gsettings", "set", "org.gnome.system.proxy", "mode", "manual"],
        base + ["gsettings", "set", "org.gnome.system.proxy.http", "host", host],
        base + ["gsettings", "set", "org.gnome.system.proxy.http", "port", str(PROXY_PORT)],
        base + ["gsettings", "set", "org.gnome.system.proxy.https", "host", host],
        base + ["gsettings", "set", "org.gnome.system.proxy.https", "port", str(PROXY_PORT)],
        base + ["gsettings", "set", "org.gnome.system.proxy.ftp", "host", host],
        base + ["gsettings", "set", "org.gnome.system.proxy.ftp", "port", str(PROXY_PORT)],
        base + ["gsettings", "set", "org.gnome.system.proxy", "ignore-hosts", "['localhost', '127.0.0.1', '::1']"],
    ]
    failed = False
    for command in commands:
        result = run(command, check=False, timeout=10, env=env)
        output = result.stdout.lower()
        if result.returncode != 0 or "failed to commit changes" in output:
            failed = True

    if failed:
        log("GNOME desktop proxy could not be fully applied. System-wide proxy is still configured.")
        return "CHECK"

    log("Ubuntu desktop proxy enabled in manual mode for current user session.")
    return "OK"


def configure_cursor_settings(prefix, user_info):
    home = Path(user_info.pw_dir)
    settings_path = home / ".config" / "Cursor" / "User" / "settings.json"
    if not settings_path.parent.exists():
        log("Cursor settings directory not found, skipping Cursor app proxy.")
        return "SKIPPED"

    settings = {}
    if settings_path.exists() and settings_path.stat().st_size > 0:
        try:
            settings = json.loads(settings_path.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            log(f"Cursor settings file is not valid JSON, skipping: {settings_path}")
            return "CHECK"

    settings["http.proxy"] = proxy_url(prefix).rstrip("/")
    settings["http.proxySupport"] = "override"
    settings_path.write_text(json.dumps(settings, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    chown_to_user(settings_path, user_info)
    log(f"Cursor app proxy configured in {settings_path}. Restart Cursor to apply it.")
    return "OK"


def configure_user_app_proxy(prefix):
    user_info = target_user_record()
    if not user_info:
        log("User app proxy: no sudo desktop user detected, skipping.")
        return "SKIPPED"

    url = proxy_url(prefix)
    home = Path(user_info.pw_dir)
    env_dir = home / ".config" / "environment.d"
    env_file = env_dir / "95-iitd-proxy.conf"
    env_content = "\n".join(
        [
            f"http_proxy={url}",
            f"https_proxy={url}",
            f"ftp_proxy={url}",
            f"HTTP_PROXY={url}",
            f"HTTPS_PROXY={url}",
            f"FTP_PROXY={url}",
            f"no_proxy={NO_PROXY}",
            f"NO_PROXY={NO_PROXY}",
        ]
    )
    env_dir.mkdir(parents=True, exist_ok=True)
    env_file.write_text(env_content + "\n", encoding="utf-8")
    os.chown(env_dir, user_info.pw_uid, user_info.pw_gid)
    chown_to_user(env_file, user_info)
    log(f"User environment proxy configured in {env_file}")

    wgetrc = home / ".wgetrc"
    replace_managed_block(
        wgetrc,
        "\n".join(
            [
                "use_proxy = on",
                f"http_proxy = {url}",
                f"https_proxy = {url}",
                f"ftp_proxy = {url}",
                f"no_proxy = {NO_PROXY}",
            ]
        ),
    )
    chown_to_user(wgetrc, user_info)
    log(f"wget proxy configured in {wgetrc}")

    curlrc = home / ".curlrc"
    replace_managed_block(
        curlrc,
        "\n".join(
            [
                f'proxy = "{url}"',
                f'noproxy = "{NO_PROXY}"',
            ]
        ),
    )
    chown_to_user(curlrc, user_info)
    log(f"curl proxy configured in {curlrc}")

    uid = user_info.pw_uid
    runtime_dir = f"/run/user/{uid}"
    dbus = f"unix:path={runtime_dir}/bus"
    runtime_env = proxy_env(prefix)
    runtime_env.update(
        {
            "DISPLAY": os.environ.get("DISPLAY", ":0"),
            "DBUS_SESSION_BUS_ADDRESS": dbus,
            "XDG_RUNTIME_DIR": runtime_dir,
        }
    )

    if Path(runtime_dir, "bus").exists():
        keys = [
            "http_proxy",
            "https_proxy",
            "ftp_proxy",
            "HTTP_PROXY",
            "HTTPS_PROXY",
            "FTP_PROXY",
            "no_proxy",
            "NO_PROXY",
        ]
        run(["sudo", "-u", user_info.pw_name, "systemctl", "--user", "import-environment"] + keys, check=False, timeout=15, env=runtime_env)
        if shutil.which("dbus-update-activation-environment"):
            run(
                ["sudo", "-u", user_info.pw_name, "dbus-update-activation-environment", "--systemd"] + keys,
                check=False,
                timeout=15,
                env=runtime_env,
            )
    else:
        log("User runtime DBus session not found; GUI apps may need logout/login.")

    cursor_status = configure_cursor_settings(prefix, user_info)
    log("Restart already-open GUI apps, including Cursor, to use the new proxy.")
    return "OK" if cursor_status in {"OK", "SKIPPED"} else "CHECK"


def package_installed(package):
    if not shutil.which("dpkg-query"):
        return False
    result = subprocess.run(
        ["dpkg-query", "-W", "-f=${Status}", package],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    return result.returncode == 0 and "install ok installed" in result.stdout


def repair_package_database(env):
    if not shutil.which("dpkg") or not shutil.which("apt-get"):
        return

    run(["dpkg", "--configure", "-a"], check=False, timeout=180, env=env)
    run(["apt-get", "-f", "install", "-y"], check=False, timeout=300, env=env)


def install_missing_mandatory_packages(prefix):
    missing = [pkg for pkg in MANDATORY_PACKAGES if not package_installed(pkg)]
    if not missing:
        log("Mandatory packages already installed. Skipping package installation.")
        return []

    if not shutil.which("apt-get"):
        raise ProxyError(f"Missing mandatory packages and apt-get is unavailable: {', '.join(missing)}")

    env = proxy_env(prefix)
    log("Missing mandatory packages: " + ", ".join(missing))
    repair_package_database(env)
    run(["apt-get", "update"], timeout=900, env=env)
    run(["apt-get", "install", "-y"] + missing, timeout=900, env=env)

    still_missing = [pkg for pkg in MANDATORY_PACKAGES if not package_installed(pkg)]
    if still_missing:
        raise ProxyError("Could not install mandatory packages: " + ", ".join(still_missing))

    return missing


def load_state():
    if not STATE_FILE.exists():
        return {}
    try:
        return json.loads(STATE_FILE.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}


def save_state(prefix, ubuntu, installed_packages):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    state = load_state()
    state.update(
        {
            "proxy_host": proxy_host(prefix),
            "proxy_port": PROXY_PORT,
            "ubuntu": ubuntu,
            "mandatory_packages": list(MANDATORY_PACKAGES),
            "installed_this_run": installed_packages,
            "updated_at": time.strftime("%Y-%m-%d %H:%M:%S"),
        }
    )
    STATE_FILE.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    log(f"Updated {STATE_FILE}")


def remove_path(path):
    try:
        if path.exists():
            path.unlink()
            log(f"Removed {path}")
    except OSError as exc:
        log(f"Could not remove {path}: {exc}")


def remove_environment_entries():
    managed_keys = {
        "http_proxy",
        "https_proxy",
        "ftp_proxy",
        "HTTP_PROXY",
        "HTTPS_PROXY",
        "FTP_PROXY",
        "no_proxy",
        "NO_PROXY",
    }
    if not ENV_FILE.exists():
        return

    kept = []
    for line in ENV_FILE.read_text(encoding="utf-8", errors="ignore").splitlines():
        key = line.split("=", 1)[0].strip() if "=" in line else ""
        if key not in managed_keys:
            kept.append(line)
    ENV_FILE.write_text("\n".join(kept).rstrip() + ("\n" if kept else ""), encoding="utf-8")
    log(f"Cleaned proxy entries from {ENV_FILE}")


def remove_snap_proxy():
    if not shutil.which("snap"):
        return "SKIPPED"
    run(["snap", "unset", "system", "proxy.http", "proxy.https"], check=False, timeout=30)
    return "OK"


def remove_gsettings_proxy():
    if not shutil.which("gsettings"):
        return "SKIPPED"

    user_info = target_user_record()
    if not user_info:
        return "SKIPPED"

    runtime_dir = f"/run/user/{user_info.pw_uid}"
    env = os.environ.copy()
    env.update(
        {
            "DISPLAY": os.environ.get("DISPLAY", ":0"),
            "DBUS_SESSION_BUS_ADDRESS": f"unix:path={runtime_dir}/bus",
            "XDG_RUNTIME_DIR": runtime_dir,
        }
    )

    base = [
        "sudo",
        "-u",
        user_info.pw_name,
        "env",
        f"DISPLAY={env['DISPLAY']}",
        f"DBUS_SESSION_BUS_ADDRESS={env['DBUS_SESSION_BUS_ADDRESS']}",
        f"XDG_RUNTIME_DIR={runtime_dir}",
    ]
    commands = [
        base + ["gsettings", "set", "org.gnome.system.proxy", "mode", "none"],
        base + ["gsettings", "set", "org.gnome.system.proxy.http", "host", ""],
        base + ["gsettings", "set", "org.gnome.system.proxy.http", "port", "0"],
        base + ["gsettings", "set", "org.gnome.system.proxy.https", "host", ""],
        base + ["gsettings", "set", "org.gnome.system.proxy.https", "port", "0"],
        base + ["gsettings", "set", "org.gnome.system.proxy.ftp", "host", ""],
        base + ["gsettings", "set", "org.gnome.system.proxy.ftp", "port", "0"],
    ]
    failed = False
    for command in commands:
        result = run(command, check=False, timeout=10, env=env)
        if result.returncode != 0 or "failed to commit changes" in result.stdout.lower():
            failed = True

    if failed:
        log("Ubuntu desktop proxy could not be fully disabled.")
        return "CHECK"

    log("Ubuntu desktop proxy disabled.")
    return "OK"


def looks_like_iitd_proxy(value):
    if not isinstance(value, str):
        return False
    parsed = urllib.parse.urlparse(value)
    return parsed.scheme in {"http", "https"} and parsed.hostname and parsed.hostname.startswith("10.10.") and parsed.port == PROXY_PORT


def clear_user_runtime_proxy(user_info):
    runtime_dir = f"/run/user/{user_info.pw_uid}"
    if not Path(runtime_dir, "bus").exists():
        return

    keys = [
        "http_proxy",
        "https_proxy",
        "ftp_proxy",
        "HTTP_PROXY",
        "HTTPS_PROXY",
        "FTP_PROXY",
        "no_proxy",
        "NO_PROXY",
    ]
    env = os.environ.copy()
    env.update(
        {
            "DISPLAY": os.environ.get("DISPLAY", ":0"),
            "DBUS_SESSION_BUS_ADDRESS": f"unix:path={runtime_dir}/bus",
            "XDG_RUNTIME_DIR": runtime_dir,
        }
    )
    run(["sudo", "-u", user_info.pw_name, "systemctl", "--user", "unset-environment"] + keys, check=False, timeout=15, env=env)
    log("Cleared proxy variables from running user systemd session.")


def remove_user_app_proxy():
    user_info = target_user_record()
    if not user_info:
        return "SKIPPED"

    home = Path(user_info.pw_dir)
    remove_path(home / ".config" / "environment.d" / "95-iitd-proxy.conf")
    remove_managed_block(home / ".wgetrc")
    remove_managed_block(home / ".curlrc")
    clear_user_runtime_proxy(user_info)

    state = load_state()
    expected_proxy = None
    if state.get("proxy_host") and state.get("proxy_port"):
        expected_proxy = f"http://{state['proxy_host']}:{state['proxy_port']}"

    cursor_settings = home / ".config" / "Cursor" / "User" / "settings.json"
    if cursor_settings.exists():
        try:
            settings = json.loads(cursor_settings.read_text(encoding="utf-8"))
            cursor_proxy = settings.get("http.proxy")
            if cursor_proxy == expected_proxy or looks_like_iitd_proxy(cursor_proxy):
                settings.pop("http.proxy", None)
                if settings.get("http.proxySupport") == "override":
                    settings.pop("http.proxySupport", None)
                cursor_settings.write_text(json.dumps(settings, indent=2, sort_keys=True) + "\n", encoding="utf-8")
                chown_to_user(cursor_settings, user_info)
                log(f"Removed Cursor app proxy from {cursor_settings}")
        except json.JSONDecodeError:
            log(f"Could not parse Cursor settings during remove: {cursor_settings}")

    return "OK"


def remove_proxy():
    require_root()
    remove_path(APT_PROXY_FILE)
    remove_path(PROFILE_FILE)
    remove_path(SYSTEMD_PROXY_FILE)
    remove_path(SYSTEMD_USER_PROXY_FILE)
    remove_environment_entries()
    snap_status = remove_snap_proxy()
    gnome_status = remove_gsettings_proxy()
    user_app_status = remove_user_app_proxy()

    if shutil.which("systemctl"):
        run(["systemctl", "daemon-reexec"], check=False, timeout=15)

    if STATE_FILE.exists():
        remove_path(STATE_FILE)

    log("Remove complete.")
    log(f"Snap: {snap_status}")
    log(f"GNOME: {gnome_status}")
    log(f"User apps: {user_app_status}")


def test_python_proxy(prefix):
    opener = urllib.request.build_opener(
        urllib.request.ProxyHandler(
            {
                "http": proxy_url(prefix),
                "https": proxy_url(prefix),
            }
        )
    )
    urls = [
        "http://archive.ubuntu.com/ubuntu/",
        "http://security.ubuntu.com/ubuntu/",
        "http://connectivity-check.ubuntu.com/",
    ]

    last_error = None
    for url in urls:
        req = urllib.request.Request(url, headers={"User-Agent": "iitd-proxy/1.0"})
        try:
            with opener.open(req, timeout=15) as response:
                if 200 <= response.status < 500:
                    return True
        except Exception as exc:  # noqa: BLE001 - verification should report and continue.
            last_error = exc

    log(f"Python proxy test failed: {last_error}")
    return False


def verify_apt_config():
    if not APT_PROXY_FILE.exists():
        return False
    text = APT_PROXY_FILE.read_text(encoding="utf-8", errors="ignore")
    return "Acquire::http::Proxy" in text and "Acquire::https::Proxy" in text


def verify_snap_config():
    if not shutil.which("snap"):
        return "SKIPPED"
    result = run(["snap", "get", "system", "proxy.http"], check=False, timeout=20)
    if result.returncode != 0 or "http://" not in result.stdout:
        return "CHECK"

    connectivity = run(["snap", "debug", "connectivity"], check=False, timeout=60)
    if connectivity.returncode != 0:
        log("Snap connectivity check failed. Try after reconnecting LAN and rerunning setup.")
        return "CHECK"

    return "OK"


def run_full_apt_test(prefix):
    if not shutil.which("apt-get"):
        return "SKIPPED"
    result = run(["apt-get", "update"], check=False, timeout=900, env=proxy_env(prefix))
    return "OK" if result.returncode == 0 else "CHECK"


def verification_report(prefix, ubuntu, full_test=False):
    report = {
        "Ubuntu Version": ubuntu["version"],
        "Ubuntu Codename": ubuntu["codename"],
        "Proxy": proxy_url(prefix),
        "IITD Login": "OK",
        "Environment": "OK" if PROFILE_FILE.exists() else "CHECK",
        "APT Config": "OK" if verify_apt_config() else "CHECK",
        "SNAP": verify_snap_config(),
        "Python Internet Test": "OK" if test_python_proxy(prefix) else "CHECK",
    }

    if full_test:
        report["APT Update Test"] = run_full_apt_test(prefix)

    log("")
    log("Proxy Verification Report")
    log("-------------------------")
    for key, value in report.items():
        log(f"{key:22}: {value}")

    checks = [value for value in report.values() if value not in {"SKIPPED", proxy_url(prefix), ubuntu["version"], ubuntu["codename"]}]
    if all(value == "OK" for value in checks):
        log("Proxy Working Successfully")
    else:
        log("Proxy configured, but one or more checks need attention. See log for details.")


def install_proxy(args):
    require_root()
    ubuntu = detect_ubuntu()
    prefix = PREFIX_MAP[args.role]

    log(f"Ubuntu detected: {ubuntu['version']} ({ubuntu['codename']})")
    log(f"Selected IITD role: {args.role}")
    log(f"Proxy endpoint: {proxy_url(prefix)}")

    log("Logging in to IITD proxy...")
    login(args.role, prefix, args.userid, args.password)

    configure_apt(prefix)
    configure_environment(prefix)
    configure_systemd(prefix)
    snap_status = configure_snap(prefix)
    gnome_status = configure_gsettings(prefix)
    user_app_status = configure_user_app_proxy(prefix)
    installed_packages = install_missing_mandatory_packages(prefix)
    save_state(prefix, ubuntu, installed_packages)

    log(f"Snap setup: {snap_status}")
    log(f"GNOME setup: {gnome_status}")
    log(f"User app setup: {user_app_status}")
    verification_report(prefix, ubuntu, full_test=args.full_test)


def normalize_legacy_args(argv):
    if len(argv) >= 2 and argv[1].lower() in PREFIX_MAP:
        return [argv[0], "install"] + argv[1:]
    return argv


def build_parser():
    parser = argparse.ArgumentParser(
        description="Configure IITD proxy system-wide on Ubuntu 16.04 through 26.04.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""Examples:
  sudo ./iitd-proxy install btech USERID
  sudo ./iitd-proxy install faculty USERID
  sudo ./iitd-proxy install visitor USERID
  sudo ./iitd-proxy install mtech USERID PASSWORD --full-test
  sudo ./iitd-proxy remove

Backward compatible form also works:
  sudo ./iitd-proxy btech USERID PASSWORD
""",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    install = subparsers.add_parser("install", aliases=("setup",), help="login and configure proxy")
    install.add_argument("role", choices=sorted(PREFIX_MAP), help="IITD proxy role")
    install.add_argument("userid", help="IITD proxy userid")
    install.add_argument("password", nargs="?", help="IITD proxy password; prompted if omitted")
    install.add_argument(
        "--full-test",
        action="store_true",
        help="also run apt-get update during verification",
    )

    subparsers.add_parser("remove", help="remove proxy configuration")
    return parser


def main():
    argv = normalize_legacy_args(sys.argv)
    parser = build_parser()
    args = parser.parse_args(argv[1:])

    try:
        if args.command in {"install", "setup"}:
            if not args.password:
                args.password = getpass.getpass("IITD proxy password: ")
            install_proxy(args)
        elif args.command == "remove":
            remove_proxy()
        else:
            parser.error("Unknown command")
    except KeyboardInterrupt:
        print("\nInterrupted", file=sys.stderr)
        return 130
    except ProxyError as exc:
        log(f"ERROR: {exc}")
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
